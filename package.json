{
  "name": "andres-kase-v2",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "browserslist": [
    "chrome >= 100",
    "safari >= 15.4",
    "ios >= 15.4",
    "firefox >= 100",
    "edge >= 100"
  ],
  "scripts": {
    "dev": "next dev --webpack",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev --webpack",
    "dev:turbo": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "sanity:export": "sanity dataset export",
    "sanity:import": "sanity dataset import",
    "sanity:validate": "sanity dataset validate",
    "upload:sanity": "node scripts/uploadData.mjs",
    "upload:sanity:dry": "node scripts/uploadData.mjs --dry-run all",
    "fetch:wp-posts": "node scripts/fetchWpPosts.mjs",
    "fetch:blogi-posts": "node scripts/fetchBlogiPosts.mjs",
    "fetch:blogi-posts:page1": "node scripts/fetchBlogiPosts.mjs --page=1 --out=posts-page1.json",
    "fetch:blogi-posts:page2": "node scripts/fetchBlogiPosts.mjs --page=2 --out=posts-page2.json",
    "import:posts:page1": "node scripts/import-posts.mjs --file=posts-page1.json",
    "import:posts:page2": "node scripts/import-posts.mjs --file=posts-page2.json",
    "migrate:import-post-type": "node scripts/migrate-import-post-type.mjs",
    "restore:blog-covers": "node scripts/restore-blog-covers.mjs",
    "restore:blog-covers:custom": "node scripts/restore-blog-covers-custom.mjs",
    "fix:blog-entities": "node scripts/fix-blog-html-entities.mjs",
    "fetch:partner-logos": "node scripts/fetchPartnerLogosClearbit.mjs",
    "fetch:partner-logos-sites": "node scripts/fetchPartnerLogosFromSites.mjs",
    "scrape:testimonials": "node scripts/scrapeTestimonials.mjs",
    "import:reviews": "node scripts/import-reviews.mjs",
    "import:testimonials": "node scripts/import-testimonials.mjs",
    "import:posts": "node scripts/import-posts.mjs",
    "migrate:wp-posts": "node scripts/migrate-wp-posts.mjs",
    "verify:portabletext": "node scripts/verify-portabletext.mjs",
    "apply-seo": "node scripts/apply-seo.mjs",
    "sanity:count-attributes": "node scripts/count-sanity-attributes.mjs",
    "sanity:strip-legacy": "node scripts/strip-legacy-page-fields.mjs",
    "sanity:strip-legacy:apply": "node scripts/strip-legacy-page-fields.mjs --apply",
    "sanity:restore-koolitus-hero": "node scripts/restore-koolitus-hero.mjs",
    "sanity:restore-koolitus-hero:apply": "node scripts/restore-koolitus-hero.mjs --apply",
    "sanity:inspect-about-hero": "node scripts/inspect-about-hero.mjs",
    "sanity:restore-about-hero": "node scripts/restore-about-hero.mjs",
    "sanity:restore-about-hero:apply": "node scripts/restore-about-hero.mjs --apply --include-draft",
    "sanity:restore-nine-days-program": "node scripts/restore-nine-days-program.mjs",
    "sanity:restore-nine-days-program:apply": "node scripts/restore-nine-days-program.mjs --apply",
    "sanity:migrate-9days-global": "node scripts/migrate-9days-to-global.mjs",
    "sanity:migrate-9days-global:apply": "node scripts/migrate-9days-to-global.mjs --apply",
    "sanity:migrate-legacy-blocks": "node scripts/migrate-legacy-section-blocks.mjs --dry-run",
    "sanity:migrate-legacy-blocks:apply": "node scripts/migrate-legacy-section-blocks.mjs",
    "sanity:inspect-sections": "node scripts/inspect-section-types.mjs",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke.routes.spec.ts",
    "test:e2e:seo": "playwright test e2e/seo.metadata.spec.ts",
    "test:e2e:technical": "playwright test e2e/technical.spec.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@portabletext/react": "^6.0.3",
    "@react-pdf/renderer": "^4.5.1",
    "@sanity/client": "^7.22.1",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.22.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "html-to-portable-text": "npm:@portabletext/html@^1.0.1",
    "jsdom": "^26.1.0",
    "lucide-react": "^1.12.0",
    "next": "16.2.4",
    "next-sanity": "^12.3.1",
    "node-fetch": "^3.3.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "sanity": "^5.22.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@sanity/cli": "^6.4.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
