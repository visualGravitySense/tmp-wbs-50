        defineField({
          name: 'title',
          title: 'Title',
          type: 'string',
          initialValue: 'Andres Kase',
        }),
        defineField({
          name: 'subtitle',
          title: 'Subtitle',
          type: 'string',
          initialValue: 'Programmi juht ja peakoolitaja • 25+ aastat tootmises',
