            {
              name: 'Tiina Lepik',
              role: 'Olemike juht',
              company: 'Baltic Pack',
              content: 'Parim investeering meie meeskonnale. Andres ei õpeta ainult teooriat, vaid näitab kuidas asju tegelikult tehases toimima paneb.',
