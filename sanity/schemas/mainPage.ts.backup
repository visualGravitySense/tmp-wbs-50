            {
              name: 'Jaan Tamm',
              role: 'CEO',
              company: 'MetalWorks AS',
              content: '25+ aastat kogemust on näha. Andres räägib keelt, mida tootmisinimene mõistab ja usaldab. Soovitan kõigile tootmisjuhtidele.',
              rating: 5,
            },
